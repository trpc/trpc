{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "trailingComma": "all",
  "singleQuote": true,
  "importOrder": [
    "___",
    "__",
    "^@trpc/(server|client|react-query|tanstack-react-query|next)/src/__tests__(.*)$",
    "<THIRD_PARTY_MODULES>",
    "^[./]"
  ],
  "importOrderParserPlugins": [
    "typescript",
    "jsx",
    "explicitResourceManagement"
  ],
  "sortTailwindcss": {
    "config": "./www/tailwind.config.ts"
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "__generated__/",
    ".docusaurus/",
    "**/.next/",
    "**/.nuxt",
    "**/www/build/",
    "**/www/typedoc/",
    "dist/",
    "examples/next-big-router/src/server/routers/*.ts",
    "examples/.test/diagnostics-big-router/**/*",
    "packages/tests/vendor/",
    "packages/server/src/vendor/",
    "packages/coverage/",
    "pnpm-lock.yaml",
    "www/docs/main/quickstart.mdx",
    ".turbo",
    ".vinxi",
    ".output",
    "www/docs/typedoc"
  ]
}
