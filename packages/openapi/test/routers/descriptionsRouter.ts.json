{
  "openapi": "3.1.1",
  "jsonSchemaDialect": "https://spec.openapis.org/oas/3.1/dialect/base",
  "info": {
    "title": "tRPC API",
    "version": "0.0.0"
  },
  "paths": {
    "/hello": {
      "get": {
        "operationId": "hello",
        "description": "Hello zod Procedure details",
        "tags": [
          "hello"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "data"
                      ]
                    }
                  },
                  "required": [
                    "result"
                  ]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "input",
            "in": "query",
            "required": true,
            "style": "deepObject",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Name of the user"
                    }
                  },
                  "required": [
                    "name"
                  ],
                  "additionalProperties": false,
                  "description": "Input to the procedure"
                }
              }
            }
          }
        ]
      }
    },
    "/subrouter.hello": {
      "get": {
        "operationId": "subrouter.hello",
        "description": "Hello zod Procedure details",
        "tags": [
          "subrouter"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "data"
                      ]
                    }
                  },
                  "required": [
                    "result"
                  ]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "input",
            "in": "query",
            "required": true,
            "style": "deepObject",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Name of the user"
                    },
                    "children": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "child": {
                            "type": "string",
                            "description": "Child name"
                          },
                          "gender": {
                            "type": "string",
                            "enum": [
                              "male",
                              "female",
                              "other"
                            ],
                            "description": "Child gender"
                          }
                        },
                        "required": [
                          "child",
                          "gender"
                        ],
                        "additionalProperties": false
                      },
                      "description": "An array of children"
                    }
                  },
                  "required": [
                    "name",
                    "children"
                  ],
                  "additionalProperties": false,
                  "description": "Input to the procedure"
                }
              }
            }
          }
        ]
      }
    },
    "/directArray": {
      "post": {
        "operationId": "directArray",
        "description": "direct array zod procedure",
        "tags": [
          "directArray"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "description": "element of output strings"
                          },
                          "description": "Array of output strings"
                        }
                      },
                      "required": [
                        "data"
                      ]
                    }
                  },
                  "required": [
                    "result"
                  ]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string",
                  "description": "element of inputs strings"
                },
                "description": "Array of inputs strings"
              }
            }
          }
        }
      }
    },
    "/helloInline": {
      "get": {
        "operationId": "helloInline",
        "description": "Hello Procedure details",
        "tags": [
          "helloInline"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "data"
                      ]
                    }
                  },
                  "required": [
                    "result"
                  ]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "input",
            "in": "query",
            "required": true,
            "style": "deepObject",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "doc comment on name"
                    }
                  },
                  "required": [
                    "name"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        ]
      }
    },
    "/subrouterInline.hello": {
      "get": {
        "operationId": "subrouterInline.hello",
        "description": "Hello Procedure details",
        "tags": [
          "subrouterInline"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/HelloInlineResponse"
                        }
                      },
                      "required": [
                        "data"
                      ]
                    }
                  },
                  "required": [
                    "result"
                  ]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        },
        "parameters": [
          {
            "name": "input",
            "in": "query",
            "required": true,
            "style": "deepObject",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "doc comment on name"
                    },
                    "children": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "child": {
                            "type": "string",
                            "description": "Child name"
                          },
                          "gender": {
                            "type": "string",
                            "enum": [
                              "male",
                              "female",
                              "other"
                            ],
                            "description": "Child gender"
                          }
                        },
                        "required": [
                          "child",
                          "gender"
                        ],
                        "additionalProperties": false
                      },
                      "description": "children list"
                    }
                  },
                  "required": [
                    "name",
                    "children"
                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        ]
      }
    },
    "/directArrayInline": {
      "post": {
        "operationId": "directArrayInline",
        "description": "directArrayInline procedure",
        "tags": [
          "directArrayInline"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          },
                          "description": "Array of output strings"
                        }
                      },
                      "required": [
                        "data"
                      ]
                    }
                  },
                  "required": [
                    "result"
                  ]
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Array of inputs strings"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "HelloInlineResponse": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the user"
          },
          "date": {
            "type": "string",
            "format": "date-time",
            "description": "Date of the greeting"
          }
        },
        "required": [
          "name",
          "date"
        ],
        "additionalProperties": false
      }
    },
    "responses": {
      "Error": {
        "description": "Error response",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "object",
                      "properties": {
                        "zodError": {
                          "oneOf": [
                            {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "message": {
                                    "type": "string"
                                  },
                                  "path": {
                                    "type": "array",
                                    "items": {
                                      "type": [
                                        "string",
                                        "number"
                                      ]
                                    }
                                  }
                                },
                                "required": [
                                  "message",
                                  "path"
                                ],
                                "additionalProperties": false
                              }
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "code": {
                          "type": "string",
                          "enum": [
                            "PARSE_ERROR",
                            "BAD_REQUEST",
                            "INTERNAL_SERVER_ERROR",
                            "NOT_IMPLEMENTED",
                            "BAD_GATEWAY",
                            "SERVICE_UNAVAILABLE",
                            "GATEWAY_TIMEOUT",
                            "UNAUTHORIZED",
                            "PAYMENT_REQUIRED",
                            "FORBIDDEN",
                            "NOT_FOUND",
                            "METHOD_NOT_SUPPORTED",
                            "TIMEOUT",
                            "CONFLICT",
                            "PRECONDITION_FAILED",
                            "PAYLOAD_TOO_LARGE",
                            "UNSUPPORTED_MEDIA_TYPE",
                            "UNPROCESSABLE_CONTENT",
                            "PRECONDITION_REQUIRED",
                            "TOO_MANY_REQUESTS",
                            "CLIENT_CLOSED_REQUEST"
                          ]
                        },
                        "httpStatus": {
                          "type": "number"
                        },
                        "path": {
                          "type": "string",
                          "description": "Path to the procedure that threw the error"
                        },
                        "stack": {
                          "type": "string",
                          "description": "Stack trace of the error (only in development)"
                        }
                      },
                      "required": [
                        "zodError",
                        "code",
                        "httpStatus"
                      ],
                      "additionalProperties": false
                    },
                    "message": {
                      "type": "string"
                    },
                    "code": {
                      "type": "number",
                      "enum": [
                        -32700,
                        -32600,
                        -32603,
                        -32001,
                        -32002,
                        -32003,
                        -32004,
                        -32005,
                        -32008,
                        -32009,
                        -32012,
                        -32013,
                        -32015,
                        -32022,
                        -32028,
                        -32029,
                        -32099
                      ]
                    }
                  },
                  "required": [
                    "data",
                    "message",
                    "code"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "error"
              ]
            }
          }
        }
      }
    }
  }
}
