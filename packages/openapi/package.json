{
  "name": "@trpc/openapi",
  "type": "module",
  "sideEffects": false,
  "version": "11.12.0-alpha",
  "description": "OpenAPI document generator for tRPC routers",
  "author": "KATT",
  "license": "MIT",
  "bin": {
    "trpc-openapi": "./dist/cli.js"
  },
  "homepage": "https://trpc.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trpc/trpc.git",
    "directory": "packages/openapi"
  },
  "eslintConfig": {
    "rules": {
      "no-restricted-imports": [
        "error",
        "@trpc/openapi"
      ]
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint --cache src",
    "codegen": "tsx test/scripts/codegen.run.ts",
    "typecheck": "tsc --noEmit --preserveWatchOutput --pretty"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./heyapi": {
      "import": {
        "types": "./dist/heyapi/index.d.mts",
        "default": "./dist/heyapi/index.mjs"
      },
      "require": {
        "types": "./dist/heyapi/index.d.cts",
        "default": "./dist/heyapi/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "src",
    "README.md",
    "package.json",
    "!**/*.test.*",
    "!**/__tests__",
    "!test",
    "heyapi"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.94.0",
    "@swagger-api/apidom-ls": "^1.6.0",
    "@trpc/server": "11.12.0",
    "@types/node": "^22.13.5",
    "eslint": "^9.26.0",
    "superjson": "^1.12.4",
    "tsdown": "0.12.7",
    "typescript": "^5.9.2",
    "vscode-languageserver-textdocument": "^1.0.12",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "@hey-api/client-fetch": ">=0.13.0",
    "@trpc/server": "11.12.0",
    "typescript": ">=5.7.2",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@hey-api/client-fetch": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "funding": [
    "https://trpc.io/sponsor"
  ]
}
